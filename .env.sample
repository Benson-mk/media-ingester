# Copy this file to .env. Bun loads .env automatically.

# Pexels API key (required for Pexels provider).
# Get yours at: https://www.pexels.com/api/
PEXELS_API_KEY=

# Pixabay API key (required for Pixabay provider).
# Get yours at: https://pixabay.com/api/docs/
PIXABAY_API_KEY=

# Unsplash API key (required for Unsplash provider).
# Get yours at: https://unsplash.com/oauth/applications
UNSPLASH_ACCESS_KEY=

# ── Base LLM model (required) ────────────────────────────────────────────────
# API key for AI enrichment (required when using --api).
MEDIA_INGEST_API_KEY=

# Default endpoint and model used for all calls unless overridden below.
MEDIA_INGEST_BASE_URL=https://api.openai.com/v1
MEDIA_INGEST_MODEL=gpt-4o-mini

# ── VLM override — image and video enrichment ────────────────────────────────
# Set any of these to route image/video calls to a different model or endpoint.
# A configured tier = capability declaration: if set, it handles that media type.
# Each unset field inherits from the base tier above.
# Fallback chain — image/video: VLM ?? LLM
MEDIA_INGEST_VLM_API_KEY=
MEDIA_INGEST_VLM_BASE_URL=
MEDIA_INGEST_VLM_MODEL=

# ── Audio override ────────────────────────────────────────────────────────────
# Set any of these to route audio calls to an audio-capable model.
# Each unset field inherits from the VLM tier (or base if VLM unset).
# Fallback chain — audio: AUDIO ?? VLM ?? LLM
MEDIA_INGEST_AUDIO_API_KEY=
MEDIA_INGEST_AUDIO_BASE_URL=
MEDIA_INGEST_AUDIO_MODEL=
