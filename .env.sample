# Copy this file to .env. Bun loads .env automatically.

# Pexels API key (required for Pexels provider).
# Get yours at: https://www.pexels.com/api/
PEXELS_API_KEY=

# Required when running with --api.
MEDIA_INGEST_API_KEY=

# Default endpoint + model for image/video enrichment.
# Any OpenAI-compatible endpoint. CLI flags --api-base-url / --api-model take precedence.
MEDIA_INGEST_BASE_URL=https://api.openai.com/v1
MEDIA_INGEST_MODEL=gpt-4o-mini

# Optional audio overrides. Audio enrichment needs an audio-capable model;
# point these at a different endpoint/model/key when your default model cannot hear audio.
# Each falls back to MEDIA_INGEST_BASE_URL / MEDIA_INGEST_MODEL / MEDIA_INGEST_API_KEY when unset.
MEDIA_INGEST_AUDIO_BASE_URL=
MEDIA_INGEST_AUDIO_MODEL=
MEDIA_INGEST_AUDIO_API_KEY=
